// prisma/schema.prisma
// MERA Tracker — Schema de base de datos

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum EstadoCandidato {
  EN_PROCESO
  EN_CAPACITACION
  INGRESADO
  RECHAZADO
}

enum NivelRiesgo {
  BAJO
  MEDIO
  ALTO
}

enum TipoAlerta {
  TECNICA
  CONDUCTUAL
  ASISTENCIA
}

enum EtapaAlerta {
  OPERACIONES
  RRHH
  CAPACITACION
  GENERAL
}

// ─── CAMPAÑA (configurable) ──────────────────────────────

model Campana {
  id        String   @id @default(cuid())
  codigo    String   @unique   // clave interna, ej: "ADT"
  nombre    String             // nombre para mostrar, ej: "ADT"
  activo    Boolean  @default(true)
  orden     Int      @default(0)
  createdAt DateTime @default(now())
}

// ─── GRUPO DE CAPACITACIÓN (cohorte por campaña) ─────────

model GrupoCapacitacion {
  id          String    @id @default(cuid())
  nombre      String    // "ADT — Ene 2024 G1"
  campana     String    // codigo de Campana
  site        String?   // "OLIVOS" | "PARQUE_PATRICIOS"
  fechaInicio DateTime
  fechaFin    DateTime?
  activo      Boolean   @default(true)

  candidatos  Candidato[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([campana])
}

// ─── COLABORADOR ─────────────────────────────────────────

model Candidato {
  id               String          @id @default(cuid())
  nombre           String
  dni              String          @unique
  puesto           String?
  campana          String          // codigo de Campana
  estado           EstadoCandidato @default(EN_PROCESO)
  fechaPostulacion DateTime        @default(now())
  fechaIngresoPiso DateTime?
  riesgo           NivelRiesgo     @default(BAJO)

  // Datos de contacto
  telefono         String?
  email            String?
  legajo           String?

  // Pool de talentos
  reContratable    Boolean?        // null = sin evaluar

  // Grupo de capacitación
  grupoCapId       String?
  grupoCap         GrupoCapacitacion? @relation(fields: [grupoCapId], references: [id])

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  evalOps   EvalOperaciones?
  evalRRHH  EvalRRHH?
  evalCap   EvalCapacitacion?
  alertas   Alerta[]
  historial Historial[]

  @@index([campana])
  @@index([estado])
  @@index([riesgo])
  @@index([fechaPostulacion])
  @@index([grupoCapId])
}

// ─── EVALUACIONES / FEEDBACK ─────────────────────────────

model EvalOperaciones {
  id          String    @id @default(cuid())
  candidatoId String    @unique
  candidato   Candidato @relation(fields: [candidatoId], references: [id], onDelete: Cascade)

  score       Int       @default(0) // 1-5 puntaje general
  recomendado Boolean   @default(false)
  feedback    String    @default("") @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EvalRRHH {
  id          String    @id @default(cuid())
  candidatoId String    @unique
  candidato   Candidato @relation(fields: [candidatoId], references: [id], onDelete: Cascade)

  score       Int       @default(0) // 1-5 puntaje general
  aptoC       Boolean   @default(false)
  feedback    String    @default("") @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EvalCapacitacion {
  id          String    @id @default(cuid())
  candidatoId String    @unique
  candidato   Candidato @relation(fields: [candidatoId], references: [id], onDelete: Cascade)

  score       Int        @default(0) // 1-5 puntaje final
  listo       Boolean    @default(false)
  tieneAlerta Boolean    @default(false)
  tipoAlerta  TipoAlerta?
  feedback    String     @default("") @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── ALERTAS ─────────────────────────────────────────────

model Alerta {
  id          String      @id @default(cuid())
  candidatoId String
  candidato   Candidato   @relation(fields: [candidatoId], references: [id], onDelete: Cascade)

  etapa       EtapaAlerta
  tipo        TipoAlerta
  descripcion String
  esDeEstado  Boolean     @default(false)

  createdAt DateTime @default(now())

  @@index([candidatoId])
}

// ─── HISTORIAL ───────────────────────────────────────────

model Historial {
  id          String    @id @default(cuid())
  candidatoId String
  candidato   Candidato @relation(fields: [candidatoId], references: [id], onDelete: Cascade)

  evento    String
  detalle   String?
  color     String   @default("blue")

  createdAt DateTime @default(now())

  @@index([candidatoId])
}
